  {
    "id": "9390999c79faaa95",
    "type": "function",
    "z": "c77ef4efe7977d27",
    "name": "Formatar para InfluxDB",
    "func": "var d = msg.payload;\nvar m = d.medicoes || {};\nmsg.payload = [\n  {\n    measurement: 'telemetria',\n    tags: {\n      tag:    d.tag    || 'PLT-01',\n      estado: d.estado || 'LIVRE',\n      motivo: d.motivo || 'NORMAL'\n    },\n    fields: {\n      temperatura:   parseFloat(m.temperatura)   || 0,\n      umidade:       parseFloat(m.umidade)       || 0,\n      gas_pct:       parseFloat(m.gas_pct)       || 0,\n      distancia_cm:  parseFloat(m.distancia_cm)  || 0,\n      gas_alarme:    m.gas_alarme ? 1 : 0,\n      intruso:       m.intruso    ? 1 : 0\n    },\n    timestamp: new Date()\n  }\n];\nreturn msg;",
    "outputs": 1,
    "x": 360,
    "y": 160,
    "wires": [["5967e95e29e546e6"]]
  },
  {
    "id": "3d0e6af133e4e0d1",
    "type": "function",
    "z": "c77ef4efe7977d27",
    "name": "Formatar Alerta InfluxDB",
    "func": "var d = msg.payload;\nvar m = d.medicoes || {};\nmsg.payload = [\n  {\n    measurement: 'alertas',\n    tags: {\n      tag:    d.tag    || 'PLT-01',\n      estado: d.estado || 'PERIGO',\n      motivo: d.motivo || 'DESCONHECIDO'\n    },\n    fields: {\n      temperatura:  parseFloat(m.temperatura)  || 0,\n      umidade:      parseFloat(m.umidade)      || 0,\n      gas_pct:      parseFloat(m.gas_pct)      || 0,\n      distancia_cm: parseFloat(m.distancia_cm) || 0,\n      ocorrencia:   1\n    },\n    timestamp: new Date()\n  }\n];\nreturn msg;",
    "outputs": 1,
    "x": 360,
    "y": 380,
    "wires": [["5967e95e29e546e6"]]
  },
