  {
    "id": "30d4708ceae23d6a",
    "type": "function",
    "z": "c77ef4efe7977d27",
    "name": "Distribuir Dados",
    "func": "var d = msg.payload;\nvar m = d.medicoes || {};\nreturn [\n  { payload: d.estado },\n  { payload: m.temperatura || 0 },\n  { payload: m.umidade || 0 },\n  { payload: m.gas_pct || 0 },\n  { payload: m.distancia_cm || 999 },\n  { payload: { labels: [new Date().toLocaleTimeString()], series: ['Temperatura'], data: [[m.temperatura || 0]] } }\n];",
    "outputs": 6,
    "x": 360,
    "y": 60,
    "wires": [
      ["0e082d42181273c5"],
      ["016b24093323f379"],
      ["cbd45eeb4cc17f01"],
