  {
    "id": "fb09019d3406fbcd",
    "type": "function",
    "z": "c77ef4efe7977d27",
    "name": "Formatar Telegram",
    "func": "var d = msg.payload;\nvar m = d.medicoes || {};\nvar emoji = d.estado === 'CRITICO' ? '🚨' : '⚠️';\nvar texto = emoji + ' *ALERTA — PLATAFORMA ESPACIAL*\\n';\ntexto += '📍 ' + (d.local || 'PLT-01') + '\\n';\ntexto += '🔴 Estado: *' + d.estado + '*\\n';\ntexto += '⚡ Motivo: *' + (d.motivo || '--') + '*\\n\\n';\ntexto += '🌡️ Temp: ' + (m.temperatura || '--') + ' °C\\n';\ntexto += '💨 Gás: ' + (m.gas_pct || '--') + '%\\n';\ntexto += '📏 Distância: ' + (m.distancia_cm || '--') + ' cm\\n';\ntexto += '⏰ ' + new Date().toLocaleString('pt-BR');\nmsg.payload = { chatId: 'SEU_CHAT_ID_AQUI', type: 'message', content: texto, options: { parse_mode: 'Markdown' } };\nreturn msg;",
    "outputs": 1,
    "x": 360,
